   "source": [
    "# Remove the titles  from the name column\n",
    "to_be_removed = ['Mr.', 'Miss.', 'Rev.']\n",
    "def remove_title(name):\n",
    "    for title in ['Mr.', 'Miss.', 'Rev.', \"Mrs.\"]:\n",
    "        name = name.replace(title, \"\")\n",
    "    return name.strip()\n",
    "\n",
    "df['Name'] = df['Name'].apply(remove_title)\n",
    "\n",
    "df\n"
   ]
  },
