   "source": [
    "# GEnder wise survival calculation\n",
    "sex_wise_survival = np.round(df.groupby(\"Sex\")['Survived'].count() / len(df['Survived']) * 100, 2)\n",
    "plt.figure(figsize=(10,5))\n",
    "sns.barplot(sex_wise_survival, palette=\"muted\")\n",
    "plt.ylabel(\"Survived %\")\n",
    "plt.show()\n"
   ]
