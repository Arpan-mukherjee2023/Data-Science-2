   "source": [
    "\n",
    "def class_func(cl):\n",
    "    if cl == \"1\":\n",
    "        return \"First\"\n",
    "    elif cl == \"2\":\n",
    "        return \"Second\"\n",
    "    elif cl == \"3\":\n",
    "        return \"Third\"\n",
    "    \n",
    "# make these columns categorical\n",
    "df['Survived'] = df['Survived'].astype(str)\n",
    "df['Pclass'] = df['Pclass'].astype(str).apply(class_func)\n",
    "\n",
    "df\n"
   ]
  },
